[
  {
    "id": "q_001",
    "type": "question",
    "references": null,
    "blocks": [
      {
        "id": "b_001_1",
        "type": "paragraph",
        "content": {
          "kn": [
            "ಪ್ರಶ್ನೆ ಕರ್ತ: ಎಲ್ಲಾ ದೇವರು ಒಂದೇ (ದೇವತೆಗಳು =?= ಜಿನೇಂದ್ರ ದೇವ) ?"
          ],
          "en": [
            "Inquirer: Are all Gods same (Devatas =?= Jinendra Deva)?"
          ]
        },
        "tags": [
          "Devatas",
          "Jinendra Bhagawan",
          "Equality"
        ],
        "videos": []
      }
    ]
  },
  {
    "id": "a_001",
    "type": "answer",
    "references": [
      "q_001"
    ],
    "blocks": [
      {
        "id": "b_001_2",
        "type": "paragraph",
        "content": {
          "kn": [
            "ಉತ್ತರ: ಯಾರು ಜಿನ ಶಾಸನ ದೇವತೆಗಳನ್ನು ತೀರ್ಥಂಕರ ಭಗವಂತರ ಸಮಾನರೆಂದು ಪೂಜಿಸುತ್ತಾರೋ ಅವರು ಅಧೋ / ನರಕ ಗಾಮಿಗಳಾಗುತ್ತಾರೆ."
          ],
          "en": [
            "Answer: Those who worship Jina Shasana Devatas as equal to Tirthankara Bhagawan will go to downward realms (Adhogati) / hell."
          ]
        },
        "tags": [
          "Worship Rules",
          "Naraka",
          "Adhogati",
          "Shasana Devatas"
        ],
        "shastraReferences": [
          "Agama"
        ],
        "videos": [
          {
            "url": "https://www.youtube.com/watch?v=bQLbYZxkLiI",
            "youtubeId": "bQLbYZxkLiI",
            "videoType": "standard",
            "thumbnailUrl": "https://img.youtube.com/vi/bQLbYZxkLiI/hqdefault.jpg"
          }
        ]
      }
    ]
  },
  {
    "id": "q_002",
    "type": "question",
    "references": null,
    "blocks": [
      {
        "id": "b_002_1",
        "type": "paragraph",
        "content": {
          "kn": [
            "ಪ್ರಶ್ನೆ ಕರ್ತ: ಜಿನ ಶಾಸನ ದೇವತೆಗಳ ಪೂಜೆ ಮಾಡಿದರೆ ಸಮ್ಯಕ್ತ್ವ ಮಲಿನವಾಗುವುದೇ?"
          ],
          "en": [
            "Inquirer: Will doing pooja of Jina Shasan Devata make Samyaktva impure (Malinatha)?"
          ]
        },
        "tags": [
          "Pooja",
          "Samyaktva",
          "Malinatha"
        ],
        "videos": []
      }
    ]
  },
  {
    "id": "a_002",
    "type": "answer",
    "references": [
      "q_002"
    ],
    "blocks": [
      {
        "id": "b_002_2",
        "type": "paragraph",
        "content": {
          "kn": [
            "ಉತ್ತರ: ವರದಾನ ಪಡೆಯಲು ಪೂಜೆ ಮಾಡಿದರೆ ಸಮ್ಯಕ್ತ್ವ ಮಲಿನವಾಗುವುದು. ಆದರೆ ವರದಾನದ ಇಚ್ಛೆ ಇಲ್ಲದೆ ಪೂಜೆ ಮಾಡಿದರೆ ಸಮ್ಯಕ್ತ್ವ ಮಲಿನ ಆಗದು."
          ],
          "en": [
            "Answer: If the pooja is performed with the desire to acquire boons, then Samyaktva Malinatha occurs. However, if the pooja is performed without any desire for boons, Samyaktva doesn’t become impure."
          ]
        },
        "tags": [
          "Boons",
          "Desire",
          "Samyaktva",
          "Pooja Intent"
        ],
        "videos": [
          {
            "url": "https://www.youtube.com/watch?v=u5wU3JpUrEc",
            "youtubeId": "u5wU3JpUrEc",
            "videoType": "standard",
            "thumbnailUrl": "https://img.youtube.com/vi/u5wU3JpUrEc/hqdefault.jpg"
          }
        ]
      }
    ]
  },
  {
    "id": "q_003",
    "type": "question",
    "references": null,
    "blocks": [
      {
        "id": "b_003_1",
        "type": "paragraph",
        "content": {
          "kn": [
            "ಪ್ರಶ್ನೆ ಕರ್ತ: ವರದ ಇಚ್ಛೆ ಇಲ್ಲದೆ ಜಿನ ಶಾಸನ ದೇವತೆಗಳ ಪೂಜೆ ಏಕೆ ಮಾಡುವರು ?"
          ],
          "en": [
            "Inquirer: Why would one perform pooja of Jina Shasana Devatas without any desire for boons?"
          ]
        },
        "tags": [
          "Worship Intent",
          "Shasana Devatas"
        ],
        "videos": []
      }
    ]
  },
  {
    "id": "a_003",
    "type": "answer",
    "references": [
      "q_003"
    ],
    "blocks": [
      {
        "id": "b_003_2",
        "type": "paragraph",
        "content": {
          "kn": [
            "ಉತ್ತರ: ಆಚಾರ್ಯ ಪೂಜ್ಯಪಾದ ಸ್ವಾಮಿಗಳ ಅಭಿಷೇಕ ಪಾಠದಲ್ಲಿ ಜಿನೇಂದ್ರ ಭಗವಂತರ ಪೂಜೆಯಲ್ಲಿ ದಿಕ್ಪಾಲಕರ , ಕ್ಷೇತ್ರ ಪಾಲರ , ಹಾಗು ಆಮೇಲೆ ನವ ದೇವತಗಳ ಆದಿ  ಅರ್ಘ್ಯ ಹಾಗು ಶಾಸನ ದೇವತೆಗಳ ಅರ್ಘ್ಯ ಕೊಡಬೇಕೆಂದು ಆಜ್ಞೆ ಇದೆ. ಜಿನೇಂದ್ರ ಭಗವಂತರ ಪೂಜೆ ಪೂರ್ಣವಾಗುವುದು ನವ ದೇವತಗಳ ಆದಿ ಅರ್ಘ್ಯ ಹಾಗು ಶಾಸನ ದೇವತೆಗಳ ಅರ್ಘ್ಯ ಕೊಟ್ಟ ಮೇಲೆ ಪೂಜೆ ಪೂರ್ಣವಾಗುದುವು. ಇಲ್ಲವಾದರೆ ಜಿನೇಂದ್ರ ಭಗವಂತರ ಪೂಜೆ ಪೂರ್ಣವಾಗುವುದೇ ಇಲ್ಲ ಎಂದಿದ್ದಾರೆ."
          ],
          "en": [
            "Answer: In Acharya Pujyapada Swami’s Abhishek Patha, Jinendra Bhagavan’s pooja includes argya to Dikpalas, Kshetrapalas, and subsequently to the Nava Devatas and Shasana Devatas. The pooja of Jinendra Bhagavan is complete only after offering the arghyas to the Nava Devatas and Shasana Devatas. Otherwise, Jinendra Bhagavan’s pooja doesn’t complete it seems."
          ]
        },
        "tags": [
          "Dharma Protection",
          "Samyak Drishti",
          "Pooja Dravya",
          "Reverence"
        ],
        "videos": [
          {
            "url": "https://www.youtube.com/watch?v=Cqr5gqWK_6I",
            "youtubeId": "Cqr5gqWK_6I",
            "videoType": "standard",
            "thumbnailUrl": "https://img.youtube.com/vi/Cqr5gqWK_6I/hqdefault.jpg"
          }
        ]
      },
      {
        "id": "b_003_2",
        "type": "paragraph",
        "content": {
          "kn": [
            "ಉತ್ತರ: ಜಿನ ಶಾಸನ ದೇವತೆಗಳು ಧರ್ಮದ ರಕ್ಷಣೆಗಾಗಿ ಆಗಮದಲ್ಲಿ ಸ್ಥಾಪಿತರಿದ್ದಾರೆ. ಆದ್ದರಿಂದ ಸಮ್ಯಕ್ ದೃಷ್ಟಿಯ ದ್ವಾರ ಜಿನೇಂದ್ರ ಭಗವಂತರ ದ್ರವ್ಯದ ಅಂಶವನ್ನು ದಾನದ ಪೂರ್ವಕ ಜಿನ ಶಾಸನ ದೇವತೆಗಳ ಸಮ್ಮಾನ ಮಾಡುತ್ತಾರೆ."
          ],
          "en": [
            "Answer: Jina Shasana Devatas are established in Agama for the protection of Jina Shasana. Hence Samyak Drishti offers a portion of the Jinendra Bhagawan’s pooja dravya in reverence to Jina Shasana Devatas."
          ]
        },
        "tags": [
          "Dharma Protection",
          "Samyak Drishti",
          "Pooja Dravya",
          "Reverence"
        ],
        "videos": [
          {
            "url": "https://www.youtube.com/watch?v=Cqr5gqWK_6I",
            "youtubeId": "Cqr5gqWK_6I",
            "videoType": "standard",
            "thumbnailUrl": "https://img.youtube.com/vi/Cqr5gqWK_6I/hqdefault.jpg"
          },
          {
            "url": "https://www.youtube.com/watch?v=r0HCcfrBNlo",
            "youtubeId": "r0HCcfrBNlo",
            "videoType": "standard",
            "thumbnailUrl": "https://img.youtube.com/vi/r0HCcfrBNlo/hqdefault.jpg"
          }
        ]
      }
    ]
  },
  {
    "id": "q_004",
    "type": "question",
    "references": null,
    "blocks": [
      {
        "id": "b_004_1",
        "type": "paragraph",
        "content": {
          "kn": [
            "ಶ್ಲೋಕ: ಯಜ್ಞಾಂಶ ಸುದಾನೇನ ಮಾನನೀಯ ಸುದೃಷ್ಟಿಭಿ"
          ],
          "en": [
            "Shloka: Yajñāṃśa sudānena mānanīya sudṛṣṭibhi"
          ]
        },
        "tags": [
          "Shloka",
          "Yajnansha",
          "Sudanena"
        ],
        "videos": []
      }
    ]
  },
  {
    "id": "a_004",
    "type": "answer",
    "references": [
      "q_004"
    ],
    "blocks": [
      {
        "id": "b_004_2",
        "type": "list",
        "content": {
          "kn": [
            "**ಯಜ್ಞ** = ಜಿನೇಂದ್ರ ಭಗವಂತರ ಪೂಜೆ",
            "**ಯಜ್ಞಾನಂಶ** = ಯಜ್ಞದ + ಒಂದು ಭಾಗ = ಜಿನೇಂದ್ರ ಭಗವಂತರ ಪೂಜೆಯ ದ್ರವ್ಯದ ಅಂಶ",
            "**ಸುದಾನೇನ** = ಸು + ದಾನ = ಚನ್ನಾಗಿ / ಬಹಳಷ್ಟು ದಾನ"
          ],
          "en": [
            "**Yajna** = Jinendra Bhagavan’s Pooja",
            "**Yajnansha** = Yajna + Ansha = A portion or component of Jinendra Bhagavan’s pooja dravya",
            "**Sudanena** = Su + Dana = Generously donating/offering"
          ]
        },
        "tags": [
          "Terminology",
          "Pooja Dravya"
        ],
        "videos": [
          {
            "url": "https://www.youtube.com/watch?v=r0HCcfrBNlo",
            "youtubeId": "r0HCcfrBNlo",
            "videoType": "standard",
            "thumbnailUrl": "https://img.youtube.com/vi/r0HCcfrBNlo/hqdefault.jpg"
          }
        ]
      },
      {
        "id": "b_005_2",
        "type": "quote",
        "attribution": {
          "kn": "ಜ್ಞಾನಮತಿ ಅಮ್ಮನವರು",
          "en": "Gyanmati Amma"
        },
        "content": {
          "kn": [
            "ತುಂಬಾ ಹಳೆಯದಾದ ಬಡವಾನಿ, ಮಧ್ಯ ಪ್ರದೇಶದ ಆದಿನಾಥ ಸ್ವಾಮಿಯ ಬಿಂಬದದಲ್ಲೇ ಗೋಮುಖ ಚಕ್ರೇಶ್ವರಿ ಯಕ್ಷ ಯಕ್ಷಿ ಉತ್ಕೀರ್ಣವಿದೆ."
          ],
          "en": [
            "In the very ancient idol of Adinath Swami in Badwani, Madhya Pradesh, the guardian deities Gomukha Yaksha and Chakreshwari Yakshi are carved directly into the Tirthankara idol itself."
          ]
        },
        "media": [
          {
            "type": "image",
            "url": "images/badwani_bahu_statue.jpg",
            "caption": {
              "kn": "ಬಡವಾನಿ, ಮಧ್ಯ ಪ್ರದೇಶದ ಆದಿನಾಥ ಸ್ವಾಮಿಯ ಪ್ರಾಚೀನ ಬಿಂಬ",
              "en": "Ancient idol of Adinath Swami in Badwani, Madhya Pradesh"
            },
            "printSize": "half-page"
          }
        ],
        "tags": [
          "Badwani",
          "Gomukha Yaksha",
          "Chakreshwari Yakshi"
        ],
        "videos": []
      },
      {
        "id": "b_005_3",
        "type": "quote",
        "attribution": {
          "kn": "ಆಚಾರ್ಯ ವಿದ್ಯಾಸಾಗರ ಸ್ವಾಮಿಗಳು",
          "en": "Acharya Vidyasagar Swami"
        },
        "content": {
          "kn": [
            "ಕ್ಷುಲ್ಲಕ ಧ್ಯಾನಸಾಗರ ೩೦ ನಿಮಿಷ ಚರ್ಚೆಯಲ್ಲಿ ಶಾಸನ ದೇವತಗಳು ಬೇರೆ ಇರುವುದಕ್ಕಿಂತ ಜಿನೇಂದ್ರ ಭಗವಂತರ ಬಿಂಬದಲ್ಲೇ ಇರುವುದು ಒಳ್ಳೆಯದು ಎಂದಿದ್ದರು ಎಂದು ತಿಳಿಸಿದ್ದಾರೆ ."
          ],
          "en": [
            "During a 30-minute discussion, he highlighted that rather than keeping Shasana Devatas separately, it is much better when they are integrated into the idol of Jinendra Bhagavan itself."
          ]
        },
        "tags": [
          "Vidyasagar Swami",
          "Integrated Idols"
        ],
        "videos": []
      },
      {
        "id": "b_005_4",
        "type": "quote",
        "attribution": {
          "kn": "ಕ್ಷುಲ್ಲಕ ಮುನಿ ಧ್ಯಾನ ಸಾಗರ್ ಸ್ವಾಮಿಗಳು",
          "en": "Kshullak Muni Dhyanasagar Swami"
        },
        "content": {
          "kn": [
            "ಸಮವಸರಣದಲ್ಲಿ ಮಧ್ಯದಲ್ಲಿ ಗಂಧ ಕುಟಿ , ಆ ಗಂಧ ಕುಟಿಯ ಮಧ್ಯದಲ್ಲಿ ಜಿನೇಂದ್ರ ಭಗವಂತರು . ಆ ಭಗವಂತರ ಪಕ್ಕದಲ್ಲೇ ಇವರು ಸಹಜವಾಗಿ ಸ್ಥಿತರಿರುತ್ತಾರೆ . ೧೦೦೦ ವರ್ಷಕ್ಕಿಂತ ಹಳೆಯ ಪ್ರತಿಮೆಗಳ್ಲಲಿ ಸಾಮಾನ್ಯವಾಗಿ ತೀರ್ಥಂಕರ ಪ್ರತಿಮಾಯೆಲ್ಲೇ ಶಾಸನ ದೇವತೆಗಳ ಪ್ರತಿಮೆ ಕಂಡು ಬರುವುದು ."
          ],
          "en": [
            "In the middle of Samavasarana is Gandhakuti. And, at the center is Jinendra Bhagavan seated. The Jina Shasana Devatas reside alongside him. Idols that are more than 1,000 years old usually contain Shasana Devatas in the Tirthankara idol itself."
          ]
        },
        "tags": [
          "Samavasarana",
          "Gandhakuti",
          "Ancient Idols"
        ],
        "videos": []
      }
    ]
  },
